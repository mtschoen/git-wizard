<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GitWizardUI.ViewModels"
        xmlns:controls="using:Avalonia.Controls"
        xmlns:converters="using:GitWizardUI.Converters"
        x:Class="GitWizardUI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="GitWizard"
        Width="1100" Height="700"
        Loaded="Window_Loaded">
  <Window.Resources>
    <converters:StringToThicknessConverter x:Key="StringToThicknessConverter" />
    <converters:EnumEqualsConverter x:Key="EnumEqualsConverter" />
  </Window.Resources>
  <Window.Styles>
    <!-- Bold the active Filter/Group/Sort sidebar button (parity with the retired MAUI UI). The
         `.active` class is bound per button to the matching Active* view-model property. -->
    <Style Selector="Button.active">
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Button.live">
      <Setter Property="Background" Value="#2E7D32" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Button.liveStarting">
      <Setter Property="Background" Value="#F9A825" />
      <Setter Property="Foreground" Value="Black" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
  </Window.Styles>
  <Grid ColumnDefinitions="250,*" RowDefinitions="Auto,*,Auto">

    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="5" Margin="5">
      <Button x:Name="SettingsButton" Content="Settings" Click="SettingsMenuItem_Click" FontSize="12" Padding="10,5" />
      <Button x:Name="DefenderButton" Content="Configure Windows Defender" Click="CheckWindowsDefenderMenuItem_Click" FontSize="12" Padding="10,5" />
      <Button x:Name="ClearCacheButton" Content="Clear Cache" Click="ClearCacheMenuItem_Click" FontSize="12" Padding="10,5" />
      <Button x:Name="DeleteAllFilesButton" Content="Delete All Local Files" Click="DeleteAllLocalFilesMenuItem_Click" FontSize="12" Padding="10,5" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" Grid.Column="0">
      <StackPanel Margin="5,0" Spacing="0">
        <TextBlock Text="Filter by" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Padding="5" />
        <Button x:Name="FilterPendingChanges"         Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=PendingChanges}"         ToolTip.Tip="Repositories with un-staged or pending changes"                                                  Content="Pending Changes"        FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="FilterSubmoduleCheckout"      Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=SubmoduleCheckout}"      ToolTip.Tip="Repositories with submodules which are not checked out to project pointer reference"             Content="Submodule Checkout"     FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="FilterSubmoduleUninitialized" Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=SubmoduleUninitialized}" ToolTip.Tip="Repositories submodules which have not been checked out/initialized"                              Content="Submodule Uninitialized" FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="FilterSubmoduleConfigIssue"   Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=SubmoduleConfigIssue}"   ToolTip.Tip="Repositories with submodules which are in .gitmodules but not in the index, or vice versa"        Content="Submodule Config Issue" FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="FilterDetachedHead"           Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=DetachedHead}"           ToolTip.Tip="Repositories or submodules with detached heads with pending/unstaged changes"                     Content="Detached Head"          FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="FilterMyRepositories"         Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=MyRepositories}"         ToolTip.Tip="Repositories that you have committed to (based on email in global git configuration)"             Content="My Repositories"        FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="FilterLocalOnlyCommits"       Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=LocalOnlyCommits}"       ToolTip.Tip="Repositories with commits not pushed to any remote"                                                Content="Local Only Commits"     FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="FilterStale"                  Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Stale}"                  ToolTip.Tip="Repositories with no commits in the last 30 days"                                                  Content="Stale (30+ days)"       FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="FilterDownstreamBranches"     Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=DownstreamBranches}"     ToolTip.Tip="Repositories with local branches that are merged into main/master and safe to delete"                       Content="Downstream Branches"    FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="FilterBehindRemote"           Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=BehindRemote}"           ToolTip.Tip="Repositories whose checked-out branch is behind its upstream remote (fetch first for an up to date result)" Content="Behind Remote"           FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="FilterPublishReady"           Classes.active="{Binding ActiveFilter, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=PublishReady}"           ToolTip.Tip="Repositories that are clean, on their default branch, and not behind their remote - safe to publish from" Content="Publish Ready"            FontSize="12" Click="FilterButton_Click" HorizontalAlignment="Stretch" />

        <TextBlock Text="Group by" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Padding="5" />
        <Button x:Name="GroupByDrive"     Classes.active="{Binding ActiveGroupMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=Drive}"     ToolTip.Tip="Group repositories by drive letter / root path"   Content="Drive"      FontSize="12" Click="GroupButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="GroupByRemoteUrl" Classes.active="{Binding ActiveGroupMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=RemoteUrl}" ToolTip.Tip="Group repositories by remote URL (find duplicates)" Content="Remote URL" FontSize="12" Click="GroupButton_Click" HorizontalAlignment="Stretch" />

        <TextBlock Text="Sort by" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Padding="5" />
        <Button x:Name="SortByWorkingDirectory" Classes.active="{Binding ActiveSortMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=WorkingDirectory}" ToolTip.Tip="Path to working directory, alphabetically" Content="Working Directory" FontSize="12" Click="SortButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="SortByRecentlyUsed"     Classes.active="{Binding ActiveSortMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=RecentlyUsed}"     ToolTip.Tip="Time of the most recent commit"             Content="Recently Used"      FontSize="12" Click="SortButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="SortByRemoteUrl"        Classes.active="{Binding ActiveSortMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=RemoteUrl}"        ToolTip.Tip="URL of first remote (usually origin)"        Content="Remote URL"         FontSize="12" Click="SortButton_Click" HorizontalAlignment="Stretch" />
        <Button x:Name="SortBySizeOnDisk"       Classes.active="{Binding ActiveSortMode, Converter={StaticResource EnumEqualsConverter}, ConverterParameter=SizeOnDisk}"       ToolTip.Tip="Size of repository on disk (largest first)"  Content="Size On Disk"     FontSize="12" Click="SortButton_Click" HorizontalAlignment="Stretch" />
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="Auto,30,Auto,*,Auto">
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="5" Margin="0,5">
        <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click" ToolTip.Tip="Click to refresh known repositories. Shift+click to clear the cache and rediscover all repositories." />
        <Button x:Name="FetchAndRefreshButton" Content="Fetch &amp; Refresh" Click="FetchAndRefreshButton_Click" ToolTip.Tip="Fetch all remotes before refreshing status (slower but accurate)" />
        <Button x:Name="LiveButton" Content="{Binding LiveButtonText}" Click="LiveButton_Click"
                Classes.live="{Binding IsLive}" Classes.liveStarting="{Binding IsLiveStarting}"
                IsEnabled="{Binding CanToggleLive}"
                ToolTip.Tip="Start or stop live repository monitoring (requires elevation when starting)" />
      </StackPanel>

      <TextBlock Grid.Row="1" Margin="10,0,0,0" VerticalAlignment="Center" Text="{Binding HeaderText}" />
      <TextBox Grid.Row="2" Margin="10,2" Watermark="Search repositories..." Text="{Binding SearchText, Mode=TwoWay}" />

      <ListBox Grid.Row="3" x:Name="RepositoryList" ItemsSource="{Binding Repositories}" DoubleTapped="RepositoryList_DoubleTapped">
        <ListBox.Styles>
          <!-- Stretch each row container to full width and drop its own padding so the row's Grid
               fills the entire item. Without this the Grid is only as wide as its content, leaving
               the rest of the row as dead space for right-click (ContextRequested bubbles up to the
               ListBox and never reaches a Grid the cursor isn't over). -->
          <Style Selector="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
          </Style>
        </ListBox.Styles>
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:RepositoryNodeViewModel">
            <!-- A Border (Grid has no Padding property) fills the stretched row container and is
                 hit-testable everywhere via Background="Transparent", so right-click hits the WHOLE
                 row, not just the label. Padding insets content; the ContextMenu + handler live here. -->
            <Border Background="Transparent" Padding="5,5,20,5" ContextRequested="OnRepositoryContextRequested">
              <Border.ContextMenu>
                <!-- DataContext is set in code-behind (OnRepositoryContextRequested). ContextMenu.PlacementTarget
                     is always null in Avalonia 11 (AvaloniaUI/Avalonia#16344), so the old
                     DataContext="{Binding $self.PlacementTarget.DataContext}" failed at bind time (null) and
                     blocked the natural inheritance, leaving the menu items' Tag/IsVisible unbound. -->
                <controls:ContextMenu x:DataType="vm:RepositoryNodeViewModel" IsVisible="{Binding IsNotGroupHeader}">
                  <MenuItem Header="Open in Fork"     IsVisible="{Binding IsNotGroupHeader}"  Click="OnOpenInForkClick"       Tag="{Binding .}" />
                  <MenuItem Header="Open in Explorer" Click="OnOpenInExplorerClick"            Tag="{Binding .}" />
                  <MenuItem Header="Copy working directory to clipboard" Click="OnCopyToClipboardClick" Tag="{Binding .}" />
                </controls:ContextMenu>
              </Border.ContextMenu>
              <Grid ColumnDefinitions="20,*,Auto,Auto,Auto,Auto">
              <TextBlock Grid.Column="0" Text="{Binding StatusIcon}"      Foreground="{Binding StatusColorHex}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip.Tip="{Binding StatusTooltip}" IsVisible="{Binding IsStatusVisible}" />
              <TextBlock Grid.Column="0" Text="{Binding ExpandIndicator}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsGroupHeader}" />
              <TextBlock Grid.Column="1" Text="{Binding DisplayText}" ToolTip.Tip="{Binding BehindRemoteTooltip}" VerticalAlignment="Center" FontWeight="{Binding GroupHeaderFontWeight}" Padding="{Binding ItemPaddingString, Converter={StaticResource StringToThicknessConverter}}" />
              <!-- Transient "copied" indicator: lights briefly when this row's path is copied (replaces the old modal "Copied" dialog). Right-aligned in the text column so it never shifts the action buttons. -->
              <TextBlock Grid.Column="1" Text="✓ Copied" Foreground="#28A745" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" IsVisible="{Binding JustCopied}" />
              <Button   Grid.Column="2" Content="Fork" FontSize="12" Padding="8,4" VerticalAlignment="Center" IsVisible="{Binding IsNotGroupHeader}" Click="ForkButton_Click" Tag="{Binding}" />
              <Button   Grid.Column="3" Content="&#x21bb;" FontSize="12" Padding="8,4" VerticalAlignment="Center" IsVisible="{Binding IsNotGroupHeader}" Click="DeepRefreshButton_Click" Tag="{Binding}" ToolTip.Tip="Deep refresh: fetch remotes and update index (may be slow)" />
              <Button   Grid.Column="4" Content="↪" FontSize="12" Padding="8,4" VerticalAlignment="Center" IsVisible="{Binding HasMatchingBranch}" Click="CheckoutMatchingBranchButton_Click" Tag="{Binding}" ToolTip.Tip="Check out branch whose tip matches the detached HEAD" />
              <Button   Grid.Column="5" Content="Clean" FontSize="12" Padding="8,4" VerticalAlignment="Center" IsVisible="{Binding IsNotGroupHeader}" Click="CleanDownstreamButton_Click" Tag="{Binding}" ToolTip.Tip="Delete local branches that are merged into main/master" />
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <!-- Indeterminate "Scanning…" indicator, overlaid on the empty list while a refresh discovers
           repositories (the cold-start discovery/cache-read gap before rows stream in). Hidden as
           soon as the first repo surfaces or the determinate progress bar takes over. -->
      <StackPanel Grid.Row="3" IsVisible="{Binding IsScanning}" IsHitTestVisible="False"
                  VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
        <ProgressBar IsIndeterminate="True" Width="220" Height="6" />
        <TextBlock Text="Scanning for repositories…" HorizontalAlignment="Center" Foreground="Gray" />
      </StackPanel>

      <StackPanel Grid.Row="4" IsVisible="{Binding IsProgressVisible}" Spacing="2" Margin="5,2">
        <ProgressBar Value="{Binding ProgressValue}" Minimum="0" Maximum="1" Height="8" />
        <TextBlock Text="{Binding ProgressText}" FontSize="10" HorizontalAlignment="Center" />
      </StackPanel>
    </Grid>

  </Grid>
</Window>
